                                            <div class="service-meta-option">
                                                <span class="meta-option-duration">{service.duration}</span>
                                                <span class="meta-option-price">{service.privatePrice}</span>
                                            </div>
                                        )
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            ))}
        </div>
        <div class="services-carousel-dots">
            {services.map((_, i) => (
                <button class={`carousel-dot${i === 0 ? ' active' : ''}`} aria-label={`Service ${i + 1}`} data-dot={i}></button>
            ))}
        </div>
    </div>
</section>

<script>
    document.querySelectorAll('.service-card').forEach(card => {
        const toggle  = card.querySelector('.service-toggle');
        const details = card.querySelector('.service-details');
        if (!details) return;
        card.addEventListener('click', () => {
            const isExpanded = card.classList.contains('expanded');
            card.classList.toggle('expanded');
            if (toggle) toggle.setAttribute('aria-expanded', String(!isExpanded));
            details.setAttribute('aria-hidden', String(isExpanded));
        });
    });

    // Carousel dot tracking
    const carousel = document.querySelector('.services-carousel') as HTMLElement | null;
    const dots = document.querySelectorAll('.services-carousel-dots .carousel-dot');

    if (carousel && dots.length) {
        const updateActiveDot = () => {
            const cards = carousel.querySelectorAll('.service-card');
            const carouselLeft = carousel.scrollLeft;
            const carouselWidth = carousel.clientWidth;
            let closest = 0;
            let minDist = Infinity;
            cards.forEach((card, i) => {
                const el = card as HTMLElement;
                const cardCenter = el.offsetLeft + el.offsetWidth / 2;
                const dist = Math.abs(cardCenter - carouselLeft - carouselWidth / 2);
                if (dist < minDist) { minDist = dist; closest = i; }
            });
            dots.forEach((dot, i) => dot.classList.toggle('active', i === closest));
        };

        carousel.addEventListener('scroll', updateActiveDot, { passive: true });

        dots.forEach((dot, i) => {
            dot.addEventListener('click', () => {
                const cards = carousel.querySelectorAll('.service-card');
                const card = cards[i] as HTMLElement | undefined;
                if (card) {
                    carousel.scrollTo({ left: card.offsetLeft - (carousel.clientWidth - card.offsetWidth) / 2, behavior: 'smooth' });
                }
            });
        });
    }
</script>
