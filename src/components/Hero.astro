---
import { PRAXIS } from '../data/config.js';
import { reviews, generateStars } from '../data/reviews.js';
---

<section id="home" class="hero">
    <div class="container">
        <div class="hero-content">
            <div class="hero-text">
                <h1 class="hero-title">Willkommen bei der
                    <span class="highlight">{PRAXIS.name}</span>
                </h1>
                <p class="hero-subtitle">Ihre moderne Physiotherapiepraxis für ganzheitliche Behandlung und nachhaltige Rehabilitation</p>
                <div class="hero-buttons">
                    <a href={PRAXIS.bookingUrl} target="_blank" class="btn btn-primary">Termin buchen</a>
                    <a href="/#services" class="btn btn-secondary">Unsere Leistungen</a>
                </div>
            </div>
            <div class="hero-image">
                <img src="/images/physiotherapeutin.svg" alt="Physiotherapeutin Praxis Vital & Active" loading="eager">
                <div class="hero-image-caption">
                    <span class="hero-image-name">Vanessa Sophie Jakobs</span>
                    <span class="hero-image-role">Physiotherapeutin</span>
                </div>
            </div>
        </div>
        <div class="hero-reviews">
            <div class="reviews-ticker">
                <div class="reviews-track">
                    {reviews.map(r => (
                        <div class="review-card">
                            <div class="review-stars" set:html={generateStars(r.rating)} />
                            <p class="review-comment">"{r.comment}"</p>
                            <div class="review-footer">
                                <span class="review-name">– {r.name}</span>
                                <span class="review-date">{r.date}</span>
                            </div>
                        </div>
                    ))}
                    {reviews.map(r => (
                        <div class="review-card">
                            <div class="review-stars" set:html={generateStars(r.rating)} />
                            <p class="review-comment">"{r.comment}"</p>
                            <div class="review-footer">
                                <span class="review-name">– {r.name}</span>
                                <span class="review-date">{r.date}</span>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </div>
</section>
