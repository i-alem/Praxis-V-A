---
import { PRAXIS } from '../data/config.js';

const tags = [
    'Moderne Behandlungsräume',
    'Neueste Therapiegeräte',
];

const images = [
    { src: '/images/praxis/praxis-empfang.jpg',      alt: 'Empfangsbereich'  },
    { src: '/images/praxis/praxis-therapieraum-1.jpg', alt: 'Therapieraum'   },
    { src: '/images/praxis/praxis-therapieraum-2.jpg', alt: 'Therapieraum'   },
    { src: '/images/praxis/praxis-geraeteraum.jpg',  alt: 'Geräteraum'       },
    { src: '/images/praxis/praxis-physiowall.jpg',   alt: 'Physiowall'       },
    { src: '/images/praxis/praxis-beinpresse.jpg',   alt: 'Beinpresse'       },
    { src: '/images/praxis/praxis-romboflex.jpg',    alt: 'Romboflex'        },
];
---

<section id="practice" class="practice">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Unsere Praxis</h2>
            <p class="section-subtitle">Moderne Ausstattung in angenehmer Atmosphäre</p>
        </div>

        <div class="gallery-slider">
            <div class="gallery-slides">
                {images.map((img, i) => (
                    <img
                        src={img.src}
                        alt={img.alt}
                        class="gallery-slide"
                        loading={i === 0 ? 'eager' : 'lazy'}
                    />
                ))}
            </div>

            <button class="gallery-prev" aria-label="Vorheriges Bild">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
            </button>
            <button class="gallery-next" aria-label="Nächstes Bild">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 18 15 12 9 6"/>
                </svg>
            </button>

            <div class="gallery-dots">
                {images.map((_, i) => (
                    <button
                        class={`carousel-dot${i === 0 ? ' active' : ''}`}
                        data-index={i}
                        aria-label={`Bild ${i + 1}`}
                    ></button>
                ))}
            </div>
        </div>

        <div class="practice-info">
            <p class="practice-description">In unserer modernen Physiotherapiepraxis erwartet Sie eine professionelle und persönliche Betreuung. Unser erfahrenes Team aus qualifizierten Physiotherapeuten steht Ihnen mit individuellen Behandlungskonzepten zur Seite.</p>
            <div class="practice-tags">
                {tags.map(tag => (
                    <span class="practice-tag">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        {tag}
                    </span>
                ))}
            </div>
        </div>
    </div>
</section>

<script>
(function () {
    const slider  = document.querySelector('.gallery-slider') as HTMLElement | null;
    const track   = slider?.querySelector('.gallery-slides') as HTMLElement | null;
    const prevBtn = slider?.querySelector('.gallery-prev') as HTMLButtonElement | null;
    const nextBtn = slider?.querySelector('.gallery-next') as HTMLButtonElement | null;
    const dots    = Array.from(slider?.querySelectorAll('.gallery-dots .carousel-dot') ?? []);

    if (!slider || !track || dots.length === 0) return;

    let current = 0;
    let timer = 0;

    const goTo = (n: number) => {
        current = ((n % dots.length) + dots.length) % dots.length;
        track.style.transform = `translateX(-${current * 100}%)`;
        dots.forEach((d, i) => d.classList.toggle('active', i === current));
    };

    const next = () => goTo(current + 1);
    const prev = () => goTo(current - 1);

    const resetTimer = () => {
        clearInterval(timer);
        timer = window.setInterval(next, 4500);
    };

    prevBtn?.addEventListener('click', () => { prev(); resetTimer(); });
    nextBtn?.addEventListener('click', () => { next(); resetTimer(); });
    dots.forEach((dot, i) => dot.addEventListener('click', () => { goTo(i); resetTimer(); }));

    slider.addEventListener('mouseenter', () => clearInterval(timer));
    slider.addEventListener('mouseleave', resetTimer);

    let touchX = 0;
    slider.addEventListener('touchstart', e => { touchX = (e as TouchEvent).touches[0].clientX; }, { passive: true });
    slider.addEventListener('touchend', e => {
        const diff = touchX - (e as TouchEvent).changedTouches[0].clientX;
        if (Math.abs(diff) > 40) { diff > 0 ? next() : prev(); resetTimer(); }
    }, { passive: true });

    resetTimer();
})();
</script>
