---
import { PRAXIS } from '../data/config.js';

const features = [
    'Moderne Behandlungsräume',
    'Neueste Therapiegeräte',
    'Barrierefreier Zugang',
    'Parkplätze vor Ort',
];

const images = [
    { src: 'https://images.pexels.com/photos/6111565/pexels-photo-6111565.jpeg?auto=compress&cs=tinysrgb&w=800', alt: 'Behandlungsraum' },
    { src: 'https://images.pexels.com/photos/6111368/pexels-photo-6111368.jpeg?auto=compress&cs=tinysrgb&w=800', alt: 'Therapiegeräte'  },
    { src: 'https://images.pexels.com/photos/6111707/pexels-photo-6111707.jpeg?auto=compress&cs=tinysrgb&w=800', alt: 'Empfangsbereich' },
    { src: 'https://images.pexels.com/photos/6111164/pexels-photo-6111164.jpeg?auto=compress&cs=tinysrgb&w=800', alt: 'Trainingsbereich'},
    { src: 'https://images.pexels.com/photos/6111601/pexels-photo-6111601.jpeg?auto=compress&cs=tinysrgb&w=800', alt: 'Therapieraum'   },
    { src: 'https://images.pexels.com/photos/6111355/pexels-photo-6111355.jpeg?auto=compress&cs=tinysrgb&w=800', alt: 'Wartebereich'    },
];
---

<section id="practice" class="practice">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Unsere Praxis</h2>
            <p class="section-subtitle">Moderne Ausstattung in angenehmer Atmosphäre</p>
        </div>
        <div class="practice-content">
            <div class="practice-text">
                <h3>Herzlich willkommen in der <br>{PRAXIS.name}</h3>
                <p>In unserer modernen Physiotherapiepraxis erwartet Sie eine professionelle und persönliche Betreuung. Unser erfahrenes Team aus qualifizierten Physiotherapeuten steht Ihnen mit individuellen Behandlungskonzepten zur Seite.</p>
                <div class="practice-features">
                    {features.map(f => (
                        <div class="feature">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20,6 9,17 4,12"/>
                            </svg>
                            <span>{f}</span>
                        </div>
                    ))}
                </div>
            </div>

            <div class="gallery-slider">
                <div class="gallery-slides">
                    {images.map((img, i) => (
                        <img
                            src={img.src}
                            alt={img.alt}
                            class="gallery-slide"
                            loading={i === 0 ? 'eager' : 'lazy'}
                        />
                    ))}
                </div>

                <button class="gallery-prev" aria-label="Vorheriges Bild">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 18 9 12 15 6"/>
                    </svg>
                </button>
                <button class="gallery-next" aria-label="Nächstes Bild">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="9 18 15 12 9 6"/>
                    </svg>
                </button>

                <div class="gallery-dots">
                    {images.map((_, i) => (
                        <button
                            class={`carousel-dot${i === 0 ? ' active' : ''}`}
                            data-index={i}
                            aria-label={`Bild ${i + 1}`}
                        ></button>
                    ))}
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    const slider   = document.querySelector('.gallery-slider') as HTMLElement | null;
    const track    = slider?.querySelector('.gallery-slides') as HTMLElement | null;
    const prevBtn  = slider?.querySelector('.gallery-prev') as HTMLElement | null;
    const nextBtn  = slider?.querySelector('.gallery-next') as HTMLElement | null;
    const dots     = slider?.querySelectorAll('.gallery-dots .carousel-dot') ?? [];
    const total    = dots.length;

    if (!slider || !track || total === 0) return;

    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    const goTo = (n: number) => {
        current = ((n % total) + total) % total;
        track.style.transform = `translateX(-${current * 100}%)`;
        dots.forEach((d, i) => d.classList.toggle('active', i === current));
    };

    const next = () => goTo(current + 1);
    const prev = () => goTo(current - 1);

    const resetTimer = () => {
        clearInterval(timer);
        timer = setInterval(next, 4500);
    };

    prevBtn?.addEventListener('click', () => { prev(); resetTimer(); });
    nextBtn?.addEventListener('click', () => { next(); resetTimer(); });

    dots.forEach((dot, i) => {
        dot.addEventListener('click', () => { goTo(i); resetTimer(); });
    });

    // Pause on hover
    slider.addEventListener('mouseenter', () => clearInterval(timer));
    slider.addEventListener('mouseleave', resetTimer);

    // Touch swipe
    let touchX = 0;
    slider.addEventListener('touchstart', e => { touchX = e.touches[0].clientX; }, { passive: true });
    slider.addEventListener('touchend', e => {
        const diff = touchX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 40) { diff > 0 ? next() : prev(); resetTimer(); }
    }, { passive: true });

    resetTimer();
</script>
