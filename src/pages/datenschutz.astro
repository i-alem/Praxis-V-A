import DatenschutzContent from '../components/DatenschutzContent.astro';
import Footer from '../components/Footer.astro';
import '../styles/main.css';
---

<Layout
    title="Datenschutzerklärung – Praxis Vital & Active"
    description="Datenschutzerklärung der Physiotherapiepraxis Praxis Vital & Active in Berlin."
