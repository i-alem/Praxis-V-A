---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Practice from '../components/Practice.astro';
import Footer from '../components/Footer.astro';
import '../styles/main.css';
---

<Layout
    title="Praxis Vital & Active – Physiotherapie Berlin"
    description="Ihre moderne Physiotherapiepraxis für ganzheitliche Behandlung und nachhaltige Rehabilitation in Berlin. Jetzt Termin buchen."
    ogUrl="https://www.praxis-v-a.com/"
    ogTitle="Praxis Vital & Active – Physiotherapie Berlin"
    ogDescription="Ihre moderne Physiotherapiepraxis für ganzheitliche Behandlung und nachhaltige Rehabilitation in Berlin. Jetzt Termin buchen."
>
    <Navigation />
    <main>
        <Hero />
        <Services />
        <Practice />
    </main>
    <Footer />
</Layout>

<script>
    // Smooth scroll for all anchor links on this page
    document.querySelectorAll('a[href^="#"]:not([href="#"])').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) window.scrollTo({ top: target.offsetTop - 70, behavior: 'smooth' });
        });
    });

    // Scroll animations
    const animationObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            const section = entry.target;
            const title    = section.querySelector('.section-title');
            const subtitle = section.querySelector('.section-subtitle');
            if (title) { title.style.transitionDelay = '0.1s'; title.classList.add('animate'); }
            setTimeout(() => { if (subtitle) subtitle.classList.add('animate'); }, 300);

            if (section.classList.contains('hero')) {
                section.querySelectorAll('.hero-title, .hero-subtitle, .hero-buttons, .hero-image, .hero-reviews')
                    .forEach(el => el.classList.add('animate'));
            }
            if (section.classList.contains('practice')) {
                setTimeout(() => {
                    const slider = section.querySelector('.gallery-slider');
                    if (slider) slider.classList.add('animate');
                }, 300);
                setTimeout(() => {
                    const el = section.querySelector('.practice-info');
                    if (el) el.classList.add('animate');
                }, 600);
            }
        });
    }, { threshold: 0.1, rootMargin: '0px 0px -100px 0px' });

    const cardObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                setTimeout(() => {
                    entry.target.style.opacity   = '1';
                    entry.target.style.transform = 'translateY(0)';
                }, 300);
            }
        });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

    document.querySelectorAll('.hero, .services, .practice, .reviews').forEach(s => animationObserver.observe(s));
    document.querySelectorAll('.service-card').forEach(el => {
        el.style.opacity   = '0';
        el.style.transform = 'translateY(30px)';
        el.style.transition = 'opacity 0.6s ease-out, transform 0.6s ease-out';
        cardObserver.observe(el);
    });
</script>
